generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_8mYagcpZI5lE@ep-little-dream-a4hik3ht-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

// ── Users ──────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("Developer")
  team      String   @default("Frontend")
  image     String?
  tags      String[] @default([])
  status    String   @default("offline")
  createdAt DateTime @default(now())

  projectMembers ProjectMember[]
  assignedTasks  Task[]          @relation("assignedTasks")
  messages       Message[]
  files          File[]
  updates        Update[]
  activityLogs   ActivityLog[]   @relation("ActivityPerformedBy")
  personalTasks  PersonalTask[]
  personalNotes  PersonalNote[]

  comments       Comment[]
  notifications  Notification[]
  timeEntries    TimeEntry[]
}

// ── Projects ───────────────────────────────────────────
model Project {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String   @default( "blue" )
  status          String   @default( "planning" )
  dueDate         DateTime
  budget          Float?
  estimatedHours  Int?
  createdAt       DateTime @default( now() )
  createdById     String
  
  client          Client?  @relation( fields: [clientId], references: [id] )
  clientId        String?

  members         ProjectMember[]
  tasks           Task[]
  messages        Message[]
  files           File[]
  updates         Update[]
  comments        Comment[]
}

// ── Clients ──────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  company   String?
  image     String?
  createdAt DateTime @default(now())
  projects  Project[]
}

// ── Project Members (many-to-many) ─────────────────────
model ProjectMember {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String  @default("member")

  @@unique([projectId, userId])
}

// ── Tasks ──────────────────────────────────────────────
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  done        Boolean  @default(false)
  status      String   @default("todo") // todo, in-progress, review, done
  priority    String   @default("medium") // low, medium, high, urgent
  dueDate     DateTime?
  labels      String[] @default([])
  order       Int      @default(0)
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  assignedTo  User?    @relation("assignedTasks", fields: [assignedId], references: [id])
  assignedId  String?
  createdAt   DateTime @default(now())
  
  comments    Comment[]
  timeEntries TimeEntry[]
}

// ── Comments ───────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String?
  
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
}

// ── Notifications ──────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  type      String   // 'assignment', 'comment', 'mention', 'due_date'
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // e.g., #project-detail:id
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

// ── Time Tracking ──────────────────────────────────────
model TimeEntry {
  id        String   @id @default(cuid())
  duration  Int      // in minutes
  note      String?
  date      DateTime @default(now())
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

// ── Messages (Chat) ────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  text      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

// ── Files ──────────────────────────────────────────────
model File {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("document")
  url        String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  uploadedBy User     @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime @default(now())
}

// ── Updates (Progress log) ─────────────────────────────
model Update {
  id          String   @id @default(cuid())
  title       String
  description String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime @default(now())
}

// ── Activity Log ───────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // 'project_created', 'project_deleted', 'user_created', 'user_deleted', 'user_updated'
  label       String   // human readable description
  entityName  String   // name of the entity being acted on
  performedBy User     @relation("ActivityPerformedBy", fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}

// ── Teams (Metadata for standalone/empty teams) ────────
model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ── Personal Space ─────────────────────────────────────
model PersonalTask {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
}

model PersonalNote {
  id        String   @id @default(cuid())
  content   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  updatedAt DateTime @updatedAt
}
