generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_8mYagcpZI5lE@ep-little-dream-a4hik3ht-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

// ── Users ──────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("Developer")
  team      String   @default("Frontend")
  image     String?
  tags      String[] @default([])
  status    String   @default("offline")
  createdAt DateTime @default(now())

  projectMembers ProjectMember[]
  assignedTasks  Task[]          @relation("assignedTasks")
  messages       Message[]
  files          File[]
  updates        Update[]
  activityLogs   ActivityLog[]   @relation("ActivityPerformedBy")
}

// ── Projects ───────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("blue")
  status      String   @default("planning")
  dueDate     DateTime
  createdAt   DateTime @default(now())
  createdById String

  members  ProjectMember[]
  tasks    Task[]
  messages Message[]
  files    File[]
  updates  Update[]
}

// ── Project Members (many-to-many) ─────────────────────
model ProjectMember {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String  @default("member")

  @@unique([projectId, userId])
}

// ── Tasks ──────────────────────────────────────────────
model Task {
  id         String   @id @default(cuid())
  title      String
  done       Boolean  @default(false)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  assignedTo User?    @relation("assignedTasks", fields: [assignedId], references: [id])
  assignedId String?
  createdAt  DateTime @default(now())
}

// ── Messages (Chat) ────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  text      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

// ── Files ──────────────────────────────────────────────
model File {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("document")
  url        String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  uploadedBy User     @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime @default(now())
}

// ── Updates (Progress log) ─────────────────────────────
model Update {
  id          String   @id @default(cuid())
  title       String
  description String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime @default(now())
}

// ── Activity Log ───────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // 'project_created', 'project_deleted', 'user_created', 'user_deleted', 'user_updated'
  label       String   // human readable description
  entityName  String   // name of the entity being acted on
  performedBy User     @relation("ActivityPerformedBy", fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}

// ── Teams (Metadata for standalone/empty teams) ────────
model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
